{
  "id": "power-monitor",
  "name": "Power Monitor",
  "version": "0.1.0",
  "minNoctaliaVersion": "4.1.0",
  "repository": "local",
  "author": "matt",
  "license": "MIT",
  "description": "Battery discharge meter with task-manager-style per-process power, CPU, RSS, wakeups and I/O. CPU-attributed; GPU/wifi power is not modeled.",
  "tags": [
    "Bar",
    "Panel",
    "System",
    "Power"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "intervalSeconds": 2,
      "topProcesses": 25,
      "historySamples": 120,
      "thresholdGoodW": 8,
      "thresholdWarnW": 15,
      "colorGood": "#A7C080",
      "colorWarning": "#DBBC7F",
      "colorCritical": "#E67E80",
      "showSparkline": true,
      "barShows": "power_w",
      "defaultSort": "power_w"
    }
  }
}
