{
  "id": "power-monitor",
  "name": "Power Monitor",
  "version": "0.1.0",
  "minNoctaliaVersion": "4.1.0",
  "repository": "local",
  "author": "matt",
  "license": "MIT",
  "description": "Bar widget showing total system power draw (W) from the battery while discharging.",
  "tags": [
    "Bar",
    "System",
    "Power"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "intervalSeconds": 2,
      "thresholdGoodW": 8,
      "thresholdWarnW": 15,
      "colorGood": "#A7C080",
      "colorWarning": "#DBBC7F",
      "colorCritical": "#E67E80"
    }
  }
}
